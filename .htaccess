# ==========================================================
# Dreamcraft Interiors — Apache/LiteSpeed config (Hostinger)
# ==========================================================

# ---------- Force HTTPS + non-www (canonical) ----------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http -> https
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://dreamcraftinteriors.com/$1 [R=301,L]

  # www -> non-www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://dreamcraftinteriors.com/$1 [R=301,L]
</IfModule>

# ---------- 301 redirects: old WordPress URLs -> new pages ----------
# Old blog posts (preserve their existing Google ranking)
Redirect 301 /bedroom-design-ideas/ https://dreamcraftinteriors.com/bedroom-interior-design-chennai/
Redirect 301 /elegant-modular-kitchen-designs/ https://dreamcraftinteriors.com/modular-kitchen-in-chennai/
Redirect 301 /interior-design-tips/ https://dreamcraftinteriors.com/interior-design-services-chennai/
Redirect 301 /blog/ https://dreamcraftinteriors.com/interior-design-stories/

# Old short service URLs used by the 2014 theme
Redirect 301 /wood-flooring/ https://dreamcraftinteriors.com/wooden-flooring-in-chennai/
Redirect 301 /wall-art-design/ https://dreamcraftinteriors.com/wall-art-design-in-chennai/
Redirect 301 /wall-panelling/ https://dreamcraftinteriors.com/wall-panelling-interior-design-chennai/
Redirect 301 /testimonials/ https://dreamcraftinteriors.com/interior-design-stories/

# Retire WordPress feeds/admin gracefully
Redirect 301 /feed/ https://dreamcraftinteriors.com/
Redirect 301 /wp-admin/ https://dreamcraftinteriors.com/
Redirect 301 /wp-login.php https://dreamcraftinteriors.com/

# ---------- Custom error page ----------
ErrorDocument 404 /404.html

# ---------- Compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---------- Browser caching ----------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 1 day"
</IfModule>

# ---------- Security headers ----------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---------- Directory listing off ----------
Options -Indexes
